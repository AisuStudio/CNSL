// CNSL — Phase 2 schema (NOT wired up yet; planning/start artifact).
// v1 foundation only; "later" tables are commented at the bottom.
// See data/PHASE2-MODEL.md for the full model & roadmap.
//
// To use later:
//   1) create a Supabase project, set DATABASE_URL / DIRECT_URL
//   2) npm i -D prisma && npm i @prisma/client
//   3) npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")     // pooled (PgBouncer) for the app
  directUrl = env("DIRECT_URL")       // direct connection for migrations
}

// ─── Enums ──────────────────────────────────────────────
enum Role {
  owner
  editor
  viewer
}

enum BoardKind {
  tracker
  list
  sport
  doc
  calendar
  chat
}

enum Urgency {
  today
  this_week
  later
  unsorted
}

enum Status {
  open
  in_progress
  review_input
  done
  canceled
}

// ─── Core skeleton ──────────────────────────────────────

/// Mirror of Supabase auth.users (id == auth.uid()).
model Profile {
  id          String        @id @db.Uuid
  displayName String?
  createdAt   DateTime      @default(now())

  ownedBoards Board[]       @relation("BoardOwner")
  memberships BoardMember[]
  tasks       Task[]        @relation("TaskCreatedBy")
  timeEntries TimeEntry[]
  logEntries  LogEntry[]
}

/// A container / workspace / list. `kind` decides what content hangs off it.
model Board {
  id         String        @id @default(uuid())
  ownerId    String        @db.Uuid
  owner      Profile       @relation("BoardOwner", fields: [ownerId], references: [id])
  kind          BoardKind  @default(tracker)
  name          String
  color         String?
  projectColors Json?      // per-project bar colour overrides (#18)
  rev           Int        @default(0) // optimistic-concurrency version (save-hardening)
  createdAt     DateTime   @default(now())
  archivedAt    DateTime?

  members    BoardMember[]
  tasks      Task[]
  events     Event[]
}

/// Who may access a board (= sharing). Role gates read/write.
model BoardMember {
  id        String   @id @default(uuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @default(viewer)
  createdAt DateTime @default(now())

  @@unique([boardId, userId])
}

// ─── Content: Tracker (today's model) ───────────────────

model Task {
  id             String      @id @default(uuid())
  boardId        String
  board          Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  number         Int
  project        String      @default("")
  epic           String      @default("")
  title          String      @default("") // the "task" text
  description    String      @default("")
  subtasks       Json?       // checklist of { id, text, done } (#24)
  deadline       DateTime?   // task due date/time (#142 deadlines)
  reminders      Json?       // [{ id, at?, offsetMinutes?, notifiedAt? }] (#142)
  urgency        Urgency     @default(unsorted)
  status         Status      @default(open)
  complexity     Int? // poker
  position       Float? // manual ordering
  trackedMinutes   Int       @default(0) // cached total; per-day in TimeEntry
  trackingStartedAt DateTime? // anchor while the timer runs (timestamp-based)
  archived       Boolean     @default(false)
  createdById    String?     @db.Uuid
  createdBy      Profile?    @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt // per-task row version (newer-wins sync)
  completedAt    DateTime?

  timeEntries    TimeEntry[]

  @@index([boardId])
}

// ─── Cross-cutting ──────────────────────────────────────

/// Per-day tracked minutes (replaces the Phase-1 dailyMinutes map).
model TimeEntry {
  id      String   @id @default(uuid())
  taskId  String
  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId  String   @db.Uuid
  user    Profile  @relation(fields: [userId], references: [id])
  day     DateTime @db.Date
  minutes Int      @default(0)

  @@unique([taskId, userId, day])
}

/// The quick-logger inbox (per user).
model LogEntry {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  text       String
  ts         DateTime @default(now())
  processed  Boolean  @default(false)
  taskId     String?
  taskNumber Int?
}

// ─── Note Pad (board kind='doc') ────────────────────────

/// Folder tree for notes. Flat in v1 (parentId null); nesting later.
model Folder {
  id        String   @id @default(uuid())
  boardId   String
  parentId  String? // → Folder.id (self-ref tree; plain column for now)
  name      String
  position  Float?
  createdAt DateTime @default(now())

  @@index([boardId])
}

model Note {
  id          String   @id @default(uuid())
  boardId     String
  folderId    String? // null = root
  title       String   @default("")
  body        String   @default("") // markdown
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([boardId])
}

// ─── Content: Calendar (board kind='calendar', #142) ────

model Event {
  id          String    @id @default(uuid())
  boardId     String
  board       Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title       String    @default("")
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean   @default(false)
  note        String    @default("")
  taskId      String? // optional loose link to a task (+ Task-Verknüpfung)
  recurrence  String? // RRULE-style; expanded client-side later (+ Wiederholung)
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now())

  @@index([boardId])
}

