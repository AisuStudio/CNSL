// CNSL — Phase 2 schema (NOT wired up yet; planning/start artifact).
// v1 foundation only; "later" tables are commented at the bottom.
// See data/PHASE2-MODEL.md for the full model & roadmap.
//
// To use later:
//   1) create a Supabase project, set DATABASE_URL / DIRECT_URL
//   2) npm i -D prisma && npm i @prisma/client
//   3) npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")     // pooled (PgBouncer) for the app
  directUrl = env("DIRECT_URL")       // direct connection for migrations
}

// ─── Enums ──────────────────────────────────────────────
enum Role {
  owner
  editor
  viewer
}

enum BoardKind {
  tracker
  list
  sport
  doc
  calendar
  chat
}

enum Urgency {
  today
  this_week
  later
  unsorted
}

enum Status {
  open
  in_progress
  paused
  review_input
  done
  canceled
}

// ─── Core skeleton ──────────────────────────────────────

/// Mirror of Supabase auth.users (id == auth.uid()).
model Profile {
  id          String        @id @db.Uuid
  email       String?       // C3 — synced from auth.users; lets invites resolve by email
  displayName String?
  // Public publisher handle (set once on first publish, then immutable). Used as
  // the namespace in /note/{publisherHandle}/{topic}/{slug}.
  publisherHandle String?   @unique
  createdAt   DateTime      @default(now())

  ownedBoards Board[]       @relation("BoardOwner")
  memberships BoardMember[]
  projectMemberships ProjectMember[] // C3 — project-level sharing
  tasks       Task[]        @relation("TaskCreatedBy")
  timeEntries TimeEntry[]
  logEntries  LogEntry[]
}

/// A container / workspace / list. `kind` decides what content hangs off it.
model Board {
  id         String        @id @default(uuid())
  ownerId    String        @db.Uuid
  owner      Profile       @relation("BoardOwner", fields: [ownerId], references: [id])
  kind          BoardKind  @default(tracker)
  name          String
  color         String?
  projectColors Json?      // per-project bar colour overrides (#18)
  rev           Int        @default(0) // optimistic-concurrency version (save-hardening)
  createdAt     DateTime   @default(now())
  archivedAt    DateTime?

  members    BoardMember[]
  tasks      Task[]
}

/// Who may access a board (= sharing). Role gates read/write.
model BoardMember {
  id        String   @id @default(uuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @default(viewer)
  createdAt DateTime @default(now())

  @@unique([boardId, userId])
}

/// Who may access a PROJECT (= project-level sharing, C3). Role gates read/write.
/// `projectId` is a soft ref to Project.id (no FK cascade, matching the rest of
/// the project links). `role` is a plain string ('owner' | 'editor' | 'viewer')
/// — not the Role enum — to avoid depending on that enum type existing in prod.
model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("viewer")
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

/// A pending invite to a project, by email. Resolved into a ProjectMember when
/// the invited user logs in (accept-on-login in lib/board.ts). `token` is for a
/// future link flow. `status` = 'pending' | 'accepted' | 'revoked'.
model Invite {
  id           String   @id @default(uuid())
  projectId    String
  email        String
  role         String   @default("viewer")
  token        String   @unique @default(uuid())
  status       String   @default("pending")
  invitedById  String?  @db.Uuid
  acceptedById String?  @db.Uuid
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([projectId])
}

// ─── Content: Tracker (today's model) ───────────────────

model Task {
  id             String      @id @default(uuid())
  boardId        String
  board          Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  number         Int
  project        String      @default("")
  projectId      String?     // C2 — FK to Project.id (server-resolved from name)
  epic           String      @default("")
  title          String      @default("") // the "task" text
  description    String      @default("")
  subtasks       Json?       // checklist of { id, text, done } (#24)
  urgency        Urgency     @default(unsorted)
  status         Status      @default(open)
  complexity     Int? // poker
  position       String? // manual backlog order — fractional-index key (string)
  trackedMinutes   Int       @default(0) // cached total; per-day in TimeEntry
  trackingStartedAt DateTime? // anchor while the timer runs (timestamp-based)
  archived       Boolean     @default(false)
  createdById    String?     @db.Uuid
  createdBy      Profile?    @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt // per-task row version (newer-wins sync)
  completedAt    DateTime?

  timeEntries    TimeEntry[]

  @@index([boardId])
  @@index([projectId])
}

// ─── Cross-cutting ──────────────────────────────────────

/// Per-day tracked minutes (replaces the Phase-1 dailyMinutes map).
model TimeEntry {
  id      String   @id @default(uuid())
  taskId  String
  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId  String   @db.Uuid
  user    Profile  @relation(fields: [userId], references: [id])
  day     DateTime @db.Date
  minutes Int      @default(0)

  @@unique([taskId, userId, day])
}

/// The quick-logger inbox (per user).
model LogEntry {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  text       String
  ts         DateTime @default(now())
  processed  Boolean  @default(false)
  taskId     String?
  taskNumber Int?
}

// ─── Note Pad (board kind='doc') ────────────────────────

/// Folder tree for notes. Flat in v1 (parentId null); nesting later.
model Folder {
  id        String   @id @default(uuid())
  boardId   String
  parentId  String? // → Folder.id (self-ref tree; plain column for now)
  name      String
  position  Float?
  createdAt DateTime @default(now())

  @@index([boardId])
}

model Note {
  id          String   @id @default(uuid())
  boardId     String
  folderId    String? // null = root
  title       String   @default("")
  body        String   @default("") // markdown
  project     String? // A1 — note belongs to a project (string)
  projectId   String? // C2 — FK to Project.id (server-resolved from name)
  taskId      String? // A1 — "Story text" link to a task (soft ref; UI handles dangling)
  createdById String?  @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Public publishing (/note/{handle}/{topic}/{slug}) ──
  // published=true exposes the note publicly (content rendered live). topic +
  // slug form the URL; slug is frozen on first publish so links don't break.
  // listed is a future "discoverable" flag — pre-beta it stays false (noindex).
  published   Boolean  @default(false)
  topic       String?
  slug        String?
  listed      Boolean  @default(false)

  @@unique([boardId, topic, slug])
  @@index([boardId])
  @@index([projectId])
}

// ─── Projects (registry) — Phase C1 ─────────────────────
/// A project as a first-class entity with a stable id. Persists the client
/// registry (A3); the id is what project membership/sharing references (Phase C).
/// Hangs off the tracker board today; entities still reference it by name until
/// the projectId backfill (C2).
model Project {
  id        String   @id @default(uuid())
  boardId   String
  name      String
  color     String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt // per-row version (newer-wins sync)

  @@index([boardId])
}

// ─── Calendar (board kind='calendar') — Phase B ─────────
/// A calendar event. Hangs off the tracker board today; may move to its own
/// calendar board later. `taskId`/`project` are soft string refs (the UI
/// handles a dangling link), mirroring the client CalendarEvent.
model Event {
  id         String    @id @default(uuid())
  boardId    String
  title      String    @default("")
  start      DateTime
  end        DateTime?
  allDay     Boolean   @default(false)
  note       String?
  project    String?
  projectId  String? // C2 — FK to Project.id (server-resolved from name)
  taskId     String?
  recurrence String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt // per-row version (newer-wins sync)

  @@index([boardId])
  @@index([projectId])
}

// ─── Scheduler (board kind='sport') — Phase 2 ───────────
/// A reusable schedule template (fitness programme, workshop). Sections + their
/// steps are stored as nested JSON (`sections`), matching the client Schedule —
/// they're only ever read/written as a whole, so no per-step table. Hangs off the
/// tracker board today. `project` is a soft string ref (projectId later, Phase C).
model Schedule {
  id        String   @id @default(uuid())
  boardId   String
  name      String   @default("")
  project   String?
  sections  Json?    // [{ id, name, order, steps: [{ id, name, description?, durationSeconds, order }] }]
  autoPause Boolean  @default(false) // insert a fixed rest between steps when on
  pauseBetweenSteps Int? // rest length in seconds (used when autoPause is on)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt // per-row version (newer-wins sync)

  @@index([boardId])
}

/// One played run of a Schedule ("Saved activity") — the recorded time goes here,
/// under the schedule's project. Flat; soft `scheduleId`/`project` refs.
model Activity {
  id              String   @id @default(uuid())
  boardId         String
  scheduleId      String
  scheduleName    String   @default("")
  project         String?
  startedAt       DateTime
  recordedSeconds Int      @default(0)
  completed       Boolean  @default(false)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt // per-row version (newer-wins sync)

  @@index([boardId])
}

// ─── Web Push subscriptions (running-timer badge push) ──
// One row per device subscription. The server pushes the running-timer count to
// a user's OTHER devices (skips the originating deviceId). See lib/webpush.ts +
// data/phase-push.sql.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  deviceId  String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
}

// ─── Chat (board kind='chat') — Phase 2 ─────────────────
/// A conversation: 1:1 direct message (kind='dm') or a project channel
/// (kind='channel', future). Participants are explicit rows
/// (ConversationParticipant) — that membership is what RLS keys on, so Supabase
/// Realtime delivers a message only to its participants. Soft refs throughout
/// (no FK cascade), like Event/Schedule.
model Conversation {
  id        String   @id @default(uuid())
  kind      String   @default("dm") // 'dm' | 'channel'
  projectId String? // channel only (future); null for DMs
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt // bumped per message → sort key

  @@index([projectId])
}

/// Who is in a conversation. For a DM there are exactly two rows. The participant
/// SELECT policies (data/phase-chat.sql) authorise a member to read the
/// conversation + its messages, which also gates Realtime delivery.
model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String    @db.Uuid
  lastReadAt     DateTime? // unread tracking
  createdAt      DateTime  @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

/// A chat message (append-only — no edit/delete in the MVP).
model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String   @db.Uuid
  body           String
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

